# Browser-safe variables. These are bundled into the React app.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_ANON_KEY is also supported for older Supabase projects.
VITE_STRIPE_PUBLISHABLE_KEY=

# Supabase Edge Function secrets. Store these with:
# supabase secrets set STRIPE_SECRET_KEY=... STRIPE_WEBHOOK_SECRET=... SITE_URL=...
# Never expose these in React, Vite, or any browser bundle.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SITE_URL=http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173
STRIPE_AUTOMATIC_TAX=false
